# chaff bootstrap configuration. Only paths/levels live here; module on/off,
# feeds and indicators are kept in the database (single source of truth).

# SQLite database file.
CHAFF_DB=/var/lib/chaff/chaff.db

# Control socket the CLI talks to.
CHAFF_SOCKET=/run/chaff.sock

# debug | info | warn | error
CHAFF_LOG_LEVEL=info

# nftables queue number used by the sniblock NFQUEUE hook.
CHAFF_NFQUEUE_NUM=100
