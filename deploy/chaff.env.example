# chaff bootstrap configuration. Only paths/levels live here; module on/off,
# feeds and indicators are kept in the database (single source of truth).

# SQLite database file.
CHAFF_DB=/var/lib/chaff/chaff.db

# Control socket the CLI talks to.
CHAFF_SOCKET=/run/chaff.sock

# debug | info | warn | error
CHAFF_LOG_LEVEL=info

# nftables queue number used by the sniblock NFQUEUE hook.
CHAFF_NFQUEUE_NUM=100

# Web panel (module `webui`). Listens on all interfaces by default; since the
# port is exposed, TLS is mandatory — a self-signed cert is auto-generated next
# to the DB (/var/lib/chaff/web) unless you point to your own.
CHAFF_WEB_ADDR=0.0.0.0:8787
# CHAFF_WEB_TLS_CERT=/etc/chaff/web.crt
# CHAFF_WEB_TLS_KEY=/etc/chaff/web.key
# Serve plain HTTP (only sane on loopback / behind a TLS proxy).
# CHAFF_WEB_INSECURE=1
